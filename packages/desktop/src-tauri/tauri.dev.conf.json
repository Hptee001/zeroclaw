{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZeroClaw (Dev)",
  "version": "0.3.1-dev",
  "identifier": "com.zeroclaw.desktop.dev",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../app/dist"
  },
  "app": {
    "windows": [
      {
        "title": "ZeroClaw (Dev)",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
