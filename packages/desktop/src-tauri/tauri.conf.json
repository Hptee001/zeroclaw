{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZeroClaw",
  "version": "0.3.1",
  "identifier": "com.zeroclaw.desktop",
  "build": {
    "beforeDevCommand": "pnpm -C ../app run dev",
    "beforeBuildCommand": "pnpm -C ../app run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../app/dist"
  },
  "app": {
    "windows": [
      {
        "title": "ZeroClaw",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "",
      "endpoints": []
    },
    "deep-link": {
      "desktop": {
        "schemes": ["zeroclaw"]
      }
    }
  }
}
